# PrintFlow - Apache Configuration (PRODUCTION)
# For domain root deployment (mrandmrsprintflow.com)

# Force correct MIME types
AddType application/javascript .js
AddType text/css .css

# Allow PHP to process manifest.json
<Files "manifest.json">
    <IfModule mod_php.c>
        php_flag engine on
    </IfModule>
</Files>

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect legacy /printflow/ paths to root (fixes 500/404 on moved assets)
    # EXCEPTION: Do not redirect service worker to prevent "script resource is behind a redirect"
    RewriteCond %{REQUEST_URI} !sw\.(js|php)$
    RewriteRule ^printflow/(.*)$ /$1 [R=301,L]

    # Canonical host: force non-www so session cookies stay on one host.
    RewriteCond %{HTTP_HOST} ^www\.mrandmrsprintflow\.com$ [NC]
    RewriteRule ^ https://mrandmrsprintflow.com%{REQUEST_URI} [R=301,L]

    # Serve static assets directly (CSS, JS, images, fonts, video, audio)
    RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot|mp4|webm|ogg|mp3|wav|avi)$ [NC]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Serve service worker and manifest
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} sw\.js$
    RewriteRule ^(.*)$ public/sw.php [L]
    
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} manifest\.json$
    RewriteRule ^(.*)$ public/manifest.json [L]

    # Handle login/register POST requests
    RewriteCond %{REQUEST_METHOD} POST
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} ^/login/?$
    RewriteRule ^(.*)$ public/api_login.php [L,QSA]

    RewriteCond %{REQUEST_METHOD} POST
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} ^/register/?$
    RewriteRule ^(.*)$ public/process_register.php [L,QSA]
    
    # Handle logout
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} ^/logout/?$
    RewriteRule ^(.*)$ public/logout.php [L]

    # Admin and Staff directories - serve directly (not through public)
    RewriteCond %{REQUEST_URI} ^/(admin|staff|customer)/
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect to the welcome page if accessing root
    RewriteCond %{REQUEST_URI} ^/?$
    RewriteRule ^(.*)$ public/welcome.php [L]

    # If the request is for a real file or directory in the root, serve it
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Otherwise, route through public directory (if not already there)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# Security: Prevent directory browsing
Options -Indexes

# Security: Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect config and includes (only in includes/ directory)
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} /includes/(config\.php|db\.php|auth\.php) [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# Protect .env files everywhere
<FilesMatch "\.env$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>
