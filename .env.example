# Google OAuth Credentials
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Payment receipt OCR. "auto" uses OCR.Space when its key is configured and
# falls back to local Tesseract. Without a key, local Tesseract is used directly.
# OCR remains advisory and never blocks a payment submission.
PAYMENT_OCR_PROVIDER=auto
PAYMENT_OCR_TESSERACT_PATH=
PAYMENT_OCR_TEMP_DIR=
PAYMENT_OCR_API_KEY=
PAYMENT_OCR_API_URL=https://api.ocr.space/parse/image
PAYMENT_OCR_LANGUAGE=eng
PAYMENT_OCR_TIMEOUT_SECONDS=25
